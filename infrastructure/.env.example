# Database
# Option 1: Local PostgreSQL (for development)
DATABASE_URL=postgresql://agent_user:agent_pass@db:5432/agent_mvp

# Option 2: Supabase (for production, requires VPN bypass or non-corporate network)
# DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres?sslmode=require

# Ollama (required)
# Use http://ollama:11434 for local docker-compose setup
# Use http://your-gpu-vm:11434 for remote GPU VM
OLLAMA_URL=http://ollama:11434

# MCP (optional for Ticket 1)
MCP_SERVER_URL=http://your-mcp-server:8080

# Backend (required)
BACKEND_PORT=8000
SECRET_KEY=change-this-in-production

# Open WebUI
WEBUI_PORT=3000
