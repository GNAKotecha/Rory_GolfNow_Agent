# Database Configuration
# SQLite (local development)
DATABASE_URL=sqlite:///./data/agent.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# Ollama Configuration
# Local Ollama instance
OLLAMA_URL=http://localhost:11434

# Remote Ollama instance
# OLLAMA_URL=http://ollama-host:11434

# Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# Optional: MCP Server URL (if using Model Context Protocol)
MCP_SERVER_URL=

# Database Configuration
# SQLite (local development)
DATABASE_URL=sqlite:///./data/agent.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# Ollama Configuration
# Local Ollama instance
OLLAMA_URL=http://localhost:11434

# Remote Ollama instance
# OLLAMA_URL=http://ollama-host:11434

# Security
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production

# Optional: MCP Server URL (if using Model Context Protocol)
MCP_SERVER_URL=

# Backend Configuration (usually don't need to change)
BACKEND_PORT=8000

# Langfuse Configuration
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-local-dev
LANGFUSE_SECRET_KEY=sk-lf-local-dev
LANGFUSE_HOST=http://localhost:3000

# Langfuse Docker Compose Secrets
LANGFUSE_POSTGRES_PASSWORD=langfuse_dev
LANGFUSE_NEXTAUTH_SECRET=changeme_secret_key_min_32_chars_long
LANGFUSE_SALT=changeme_salt_min_32_chars_long

# BRS repository paths
BRS_TEESHEET_PATH=/path/to/brs-teesheet
BRS_CONFIG_PATH=/path/to/brs-config-api
BRS_TOOL_TIMEOUT_MULTIPLIER=1.0
